{#
/**
 * @file
 * Document node, full view: download-focused.
 */
#}
{% if view_mode != 'full' %}
  {% include '@aabenintra/content/node--teaser.html.twig' %}
{% else %}
  {{ attach_library('aabenintra/node') }}
  <article{{ attributes.addClass('ai-doc', 'layout-container') }}>

    {{ content.aabenintra_mandatory }}

    {{ title_prefix }}
    <h1 class="ai-doc__title">{{ label }}</h1>
    {{ title_suffix }}

    <div class="ai-byline">
      {% if author_name %}<span class="ai-byline__author">{{ author_name }}</span>{% endif %}
      {% if date %}<time>{{ date }}</time>{% endif %}
    </div>

    {% for f in ai_files %}
      <a class="ai-doc__file" href="{{ f.url }}" download>
        <span class="ai-doc__icon">{{ f.ext }}</span>
        <span class="ai-doc__info">
          <span class="ai-doc__name">{{ f.name }}</span>
          <span class="ai-doc__sub">{{ f.size }} · {{ 'Download'|t }}</span>
        </span>
      </a>
    {% endfor %}

    {% set meta = ai_meta.department|merge(ai_meta.topics)|merge(ai_meta.location) %}
    {% if meta %}
      <div class="ai-pills" style="margin-block: var(--space-3, .75rem);">
        {% for m in meta %}<a class="ai-badge ai-badge--ghost" href="{{ m.url }}">{{ m.label }}</a>{% endfor %}
      </div>
    {% endif %}

    {% if content.body|render|trim %}<div class="ai-doc__body">{{ content.body }}</div>{% endif %}

    {{ content|without('field_document_file', 'body', 'field_department', 'field_topics', 'field_org_unit', 'field_location', 'aabenintra_mandatory', 'uid', 'created', 'links') }}

  </article>
{% endif %}
