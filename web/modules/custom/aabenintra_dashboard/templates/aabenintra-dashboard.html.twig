{#
/**
 * @file
 * AabenIntra personalized tile dashboard (server-rendered fallback).
 *
 * The dashboard island progressively enhances this markup (re-packing,
 * per-user order, drag-to-reorder). With JS off this renders correctly.
 *
 * Available variables:
 * - greeting: time-of-day greeting with the user's name.
 * - tiles: list of tile data (id, title, url, summary, image_url, image_alt,
 *   eyebrow, size, pinned).
 */
#}
<div class="ai-dashboard-wrap layout-container">
  <h1 class="ai-greeting">{{ greeting }}</h1>

  <div class="ai-dashboard" data-ai-dashboard>
    {% for tile in tiles %}
      <article class="tile tile--{{ tile.size }}{{ tile.pinned ? ' is-pinned' : '' }}" data-tile-id="{{ tile.id }}">
        {% if tile.image_url %}
          <a class="tile__media" href="{{ tile.url }}" tabindex="-1" aria-hidden="true">
            <img src="{{ tile.image_url }}" alt="{{ tile.image_alt }}" loading="lazy">
          </a>
        {% endif %}
        <div class="tile__body">
          {% if tile.eyebrow %}<span class="tile__eyebrow">{{ tile.eyebrow }}</span>{% endif %}
          <h2 class="tile__title"><a href="{{ tile.url }}">{{ tile.title }}</a></h2>
          {% if tile.summary %}<p class="tile__summary">{{ tile.summary }}</p>{% endif %}
          <div class="tile__meta">
            <button type="button" class="tile__pinbtn" data-ai-pin="{{ tile.id }}" aria-pressed="{{ tile.pinned ? 'true' : 'false' }}" title="{{ 'Pin to top'|t }}" aria-label="{{ 'Pin to top'|t }}">★</button>
            <span class="tile__draghandle" data-ai-drag aria-hidden="true" title="{{ 'Drag to reorder'|t }}">⠿</span>
          </div>
        </div>
      </article>
    {% else %}
      <p>{{ 'No stories yet.'|t }}</p>
    {% endfor %}
  </div>
</div>
