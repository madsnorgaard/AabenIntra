<?php

/**
 * @file
 * AabenIntra Social: reactions bar on content + theme hooks.
 */

declare(strict_types=1);

use Drupal\aabenintra_social\Service\ReactionService;
use Drupal\Core\Entity\EntityInterface;
use Drupal\node\NodeInterface;

/**
 * The content types that get comments + reactions.
 */
function _aabenintra_social_bundles(): array {
  return ['story', 'document'];
}

/**
 * Implements hook_theme().
 */
function aabenintra_social_theme(): array {
  return [
    'aabenintra_reactions' => [
      'variables' => ['nid' => 0, 'types' => [], 'counts' => [], 'mine' => NULL, 'total' => 0],
    ],
  ];
}

/**
 * Implements hook_ENTITY_TYPE_view() for nodes.
 *
 * Appends the reactions bar to the full view of bundles that carry comments.
 */
function aabenintra_social_node_view(array &$build, NodeInterface $node, $display, string $view_mode): void {
  if ($view_mode !== 'full' || !in_array($node->bundle(), _aabenintra_social_bundles(), TRUE)) {
    return;
  }
  /** @var \Drupal\aabenintra_social\Service\ReactionService $service */
  $service = \Drupal::service('aabenintra_social.reaction');
  $counts = $service->counts($node);
  $mine = $service->userReaction($node, (int) \Drupal::currentUser()->id());

  $build['aabenintra_reactions'] = [
    '#theme' => 'aabenintra_reactions',
    '#nid' => (int) $node->id(),
    '#types' => ReactionService::TYPES,
    '#counts' => $counts,
    '#mine' => $mine,
    '#total' => array_sum($counts),
    '#weight' => 200,
    '#attached' => [
      'library' => ['aabenintra_social/reactions'],
      'drupalSettings' => [
        'aabenintraSocial' => [
          'csrfToken' => \Drupal::csrfToken()->get('aabenintra_social_react'),
        ],
      ],
    ],
    '#cache' => [
      'contexts' => ['user'],
      'tags' => $node->getCacheTags(),
    ],
  ];
}
