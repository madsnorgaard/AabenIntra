# Copy to .env on VPS2 (~/docker/aabenintra.fenixnordic.solutions/.env) and fill
# in real values. This file is the production deploy gate; the pipeline skips
# any project without it. NEVER commit the real .env.

# Database
DB_NAME=aabenintra
DB_USER=aabenintra
DB_PASS=CHANGE_ME
DB_HOST=aabenintra_db
DB_PORT=3306

# Drupal
# Generate with: openssl rand -hex 32
HASH_SALT=CHANGE_ME_GENERATE_RANDOM_STRING
# Regex of allowed hostnames (escape the dots).
TRUSTED_HOSTS=aabenintra\.fenixnordic\.solutions

# Redis
REDIS_HOST=aabenintra_redis

# SMTP (mail delivery via the madsnorgaard.net mail server)
SMTP_HOST=mail.madsnorgaard.net
SMTP_PORT=587
SMTP_PROTOCOL=tls
SMTP_USER=mads@madsnorgaard.net
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM=mads@madsnorgaard.net
